NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# MongoDB Atlas connection string (URL-encode special characters in password)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=24h

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay Configuration (optional)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Notification contacts
PUBLIC_STORE_URL=http://localhost:5173
STORE_OWNER_EMAIL=owner@example.com
STORE_OWNER_PHONE=919999999999
STORE_OWNER_WHATSAPP=919999999999
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=919999999999
DEFAULT_PHONE_COUNTRY_CODE=91

# Email provider API (expects JSON: from, to, subject, html, text)
EMAIL_API_URL=https://api.your-email-provider.com/emails
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=Bhagyam Exports <orders@example.com>

# WhatsApp Business Cloud API
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# Optional: use an approved template instead of a text message
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# SMS provider API (expects JSON: to, from, message)
SMS_API_URL=https://api.your-sms-provider.com/messages
SMS_API_KEY=your_sms_api_key
SMS_FROM=FashionStore
